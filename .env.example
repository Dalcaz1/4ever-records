# Copy this file to .env.local and fill in your values

# ── Supabase (Database) ──────────────────────────────────────
# Get these from https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# ── Square (Payments) ────────────────────────────────────────
# Get these from https://developer.squareup.com → Applications
NEXT_PUBLIC_SQUARE_APP_ID=your_square_app_id_here
NEXT_PUBLIC_SQUARE_LOCATION_ID=your_square_location_id_here
SQUARE_ACCESS_TOKEN=your_square_access_token_here
# Set to 'sandbox' for testing, 'production' for real payments
SQUARE_ENVIRONMENT=sandbox

# ── Discogs (Vinyl Pricing) ──────────────────────────────────
# Get from https://www.discogs.com/settings/developers → Generate Token
DISCOGS_TOKEN=your_discogs_personal_access_token

# ── USPS (Shipping) ──────────────────────────────────────────
# Register free at https://www.usps.com/business/web-tools-apis
USPS_USER_ID=your_usps_user_id_here

# ── Anthropic (AI Photo Identification) ─────────────────────
# Get from https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Site Config ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_STORE_NAME=4 Ever Memories Records
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/people/4-Ever-Memories-Record-Store/61561753862914/
NEXT_PUBLIC_STORE_EMAIL=your_email@gmail.com
NEXT_PUBLIC_STORE_PHONE=your_phone_number

# ── Shipping Defaults ────────────────────────────────────────
NEXT_PUBLIC_SHIP_FROM_ZIP=your_zip_code_here
